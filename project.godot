; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="MultiNode Demo"
run/main_scene="res://addons/multi_node/demo/demo_scene.tscn"
config/features=PackedStringArray("4.6")

[autoload]

DebugMenu="*res://addons/debug_menu/debug_menu.gd"

[editor_plugins]

enabled=PackedStringArray("res://addons/debug_menu/plugin.cfg", "res://addons/multi_node/plugin.cfg")

[physics]

3d/physics_engine="Jolt Physics"
