[node name="ReverseGravity" type="MultiNodeSub" parent="MultiNode"]
instance_every = 0
compute_code = "#version 450
layout(local_size_x = 64) in;
layout(set = 0, binding = 0, std430) buffer Transforms { vec4 transforms[]; };
layout(set = 0, binding = 1, std430) buffer ActiveFlags { uint inst_active[]; };
layout(set = 0, binding = 2, std430) buffer InstanceData { vec4 data[]; };
layout(push_constant, std430) uniform Params { float delta; float time; uint count; uint stride; };
void main() {
    uint idx = gl_GlobalInvocationID.x;
    if (idx >= count) return;
    if (inst_active[idx] == 0) return;
    // Output upward force into data[idx] — GDScript reads this and applies impulses.
    data[idx] = vec4(0.0, 19.62, 0.0, 0.0);
}"
compute_enabled = true
script = ExtResource("27")

